# ─── GMAIL OAUTH ───────────────────────────────────────────────
GMAIL_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_REFRESH_TOKEN=will_be_generated_by_auth_script

# ─── ANTHROPIC ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── GOOGLE SHEETS ─────────────────────────────────────────────
# Create a Google Sheet and paste its ID from the URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ─── GOHIGHLEVEL ───────────────────────────────────────────────
GHL_API_KEY=your_ghl_private_integration_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_PIPELINE_ID=will_be_filled_after_running_ghl_lookup
GHL_STAGE_ID=will_be_filled_after_running_ghl_lookup

# ─── APP SETTINGS ──────────────────────────────────────────────
# How often to check Gmail (in minutes)
POLL_INTERVAL_MINUTES=15
